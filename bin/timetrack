#!/usr/bin/env python3
"""timetrack — reconstruct a rough, visual picture of where YOUR attention went
each day across parallel git worktrees, for filling in timesheets.

Dumb builder, smart template: this script greps the durable signal sources,
normalises everything to LOCAL time, and emits a JSON blob that gets injected
into template.html. All timeline maths (latest-wins attention, meeting overlay,
toggles) lives in the template's JS.

v1 signals: human-typed Claude prompts + gco/gcod checkouts.
Everything is re-derived each run — no store to maintain.
"""

import argparse
import datetime as dt
import glob
import json
import os
import re
import signal
import socket
import subprocess
import sys
import threading
import time
import urllib.request
from pathlib import Path

HOME = Path.home()
CLAUDE_PROJECTS = HOME / ".claude" / "projects"
GCOD_LOG = HOME / ".timetrack" / "checkouts.log"  # written by the gco/gcod wrapper
REVIEW_LOG = HOME / ".timetrack" / "review.log"   # written by the browser extension host
FOCUS_LOG = HOME / ".timetrack" / "focus.log"     # written by the iTerm2 focus daemon
REVIEW_LANE = "__github_review__"
CONFIG_PATH = Path(__file__).resolve().parent.parent / "config.json"
TEMPLATE = Path(__file__).resolve().parent.parent / "template.html"
OUT = Path(__file__).resolve().parent.parent / "out" / "timetrack.html"
PID_FILE = HOME / ".timetrack" / "serve.pid"   # background --serve daemon state
SERVE_LOG = HOME / ".timetrack" / "serve.log"
CACHE_DIR = HOME / ".timetrack" / "cache"
HOLIDAYS_CACHE = CACHE_DIR / "holidays.json"   # {year: {fetched, items}} — holidays are static, cache hard
ICS_CACHE = CACHE_DIR / "calendar.ics"         # short-TTL cache so back-to-back regenerates skip the network
DEFAULT_PORT = 8765

JIRA_RE = re.compile(r"([A-Za-z]+-\d+)")

DEFAULTS = {
    # repo paths whose lane is pinned at the top as the "app" lane
    "app_paths": [str(HOME / "dev" / "cmr-web")],
    "ics_url": None,        # Outlook published calendar .ics (secret — keep out of git)
    "skip_meetings": [],    # meeting title substrings that default to OFF
    "jira_names": {},       # override derived names, e.g. {"PBL-7198": "EFS comparison"}
    "jira_codes": {},       # group JIRAs under a timesheet code, e.g. {"PBL-7198": "PLATFORM"}
    # personal preferences — editable in config.json or the served Settings panel
    "day_start": "08:00",   # start of the framed working day
    "day_end": "17:00",     # end of the framed working day
    "full_day": "07:30",    # "Fit to" timesheet target
    "idle_tail_min": 30,    # how long your last signal of the day keeps holding
    "round_to_min": 15,     # "Round to" granularity
    "weeks": 4,             # default number of weeks to scan when -w isn't given
    "holiday_region": "Wellington",  # NZ region for provincial anniversary days (or null = national only)
    "log_retain_weeks": 26,  # trim tick-log lines older than this on each build (0 = never trim)
}

# keys the served Settings panel is allowed to write back to config.json
EDITABLE_KEYS = {"day_start", "day_end", "full_day", "idle_tail_min", "round_to_min",
                 "weeks", "holiday_region", "skip_meetings", "log_retain_weeks"}

# NZ regions -> Nager.Date ISO-3166-2 county codes, for filtering provincial
# anniversary days. National holidays (global) are always included.
NZ_REGIONS = {
    "Auckland": "NZ-AUK", "Wellington": "NZ-WGN", "Canterbury": "NZ-CAN",
    "Otago": "NZ-OTA", "Southland": "NZ-STL", "Nelson": "NZ-NSN",
    "Marlborough": "NZ-MBH", "Taranaki": "NZ-TKI", "Hawke's Bay": "NZ-HKB",
    "Bay of Plenty": "NZ-BOP", "Waikato": "NZ-WKO", "Northland": "NZ-NTL",
    "Gisborne": "NZ-GIS", "Manawatū-Whanganui": "NZ-MWT", "West Coast": "NZ-WTC",
    "Tasman": "NZ-TAS", "Chatham Islands": "NZ-CIT",
}


def load_config():
    cfg = dict(DEFAULTS)
    if CONFIG_PATH.exists():
        try:
            cfg.update(json.loads(CONFIG_PATH.read_text()))
        except Exception as e:
            print(f"warning: could not read {CONFIG_PATH}: {e}", file=sys.stderr)
    return cfg


def hhmm_to_min(value, default):
    """'08:00' -> 480. Falls back to default on anything malformed."""
    try:
        h, m = str(value).split(":")
        return int(h) * 60 + int(m)
    except (ValueError, AttributeError):
        return default


def to_local(ts_str):
    """Parse an ISO timestamp (with Z or offset) and return a LOCAL aware datetime.
    This is the single most important function: every source must pass through it
    so morning UTC timestamps land on the correct local day."""
    if not ts_str:
        return None
    try:
        d = dt.datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
    except ValueError:
        return None
    if d.tzinfo is None:
        d = d.astimezone()  # assume local if naive
    return d.astimezone()


def minute_of(local):
    """Minutes-since-midnight as a FRACTION, so sub-minute signals don't land on
    the same integer tick and annihilate each other in the latest-wins model."""
    return round(local.hour * 60 + local.minute + local.second / 60, 3)


def jira_from(branch):
    if not branch:
        return None
    m = JIRA_RE.search(branch)
    return m.group(1).upper() if m else None


def name_from_branch(branch, jira):
    """Derive a human name for a JIRA from its branch slug.
    'pbl-7198/efs-comparison' + PBL-7198 -> 'efs comparison'."""
    if not branch or not jira:
        return None
    s = re.sub(r"^" + re.escape(jira), "", branch, flags=re.I)  # drop the tag
    s = re.sub(r"[\s/_-]+", " ", s).strip()
    return s or None


def parse_review_title(title):
    """('PR title', 'author') from a GitHub PR page <title>:
    'TRM-466 Enable strictFunctionTypes by NickR49 · Pull Request #13559 · org/repo'
    -> ('TRM-466 Enable strictFunctionTypes', 'NickR49')."""
    if not title or title.lower().startswith("http"):
        return None, None
    head = re.split(r"\s+·\s+Pull Request", title)[0]   # drop the GitHub page chrome
    m = re.search(r"\s+by\s+(\S+)\s*$", head)
    author = m.group(1) if m else None
    pr = re.sub(r"\s+by\s+\S+\s*$", "", head).strip()    # drop trailing "by <login>"
    return (pr or None), author


def name_from_review_title(title, jira):
    """Fallback name for a review-only jira when no branch was logged — derived
    from the PR title (minus the jira tag)."""
    pr, _ = parse_review_title(title)
    if not pr:
        return None
    if jira:
        pr = re.sub(r"^" + re.escape(jira) + r"[\s:_-]*", "", pr, flags=re.I).strip()
    return pr or None


def build_jira_names(events, overrides):
    from collections import Counter, defaultdict
    branch_cand = defaultdict(Counter)
    review_cand = defaultdict(Counter)
    for e in events:
        j = e.get("jira")
        if not j:
            continue
        if e.get("branch"):
            n = name_from_branch(e["branch"], j)
            if n:
                branch_cand[j][n] += 1
        elif e.get("type") == "review" and e.get("preview"):
            n = name_from_review_title(e["preview"], j)
            if n:
                review_cand[j][n] += 1
    # PR titles name review-only jiras; a branch slug wins when there's real work;
    # config overrides win over both.
    names = {j: c.most_common(1)[0][0] for j, c in review_cand.items()}
    names.update({j: c.most_common(1)[0][0] for j, c in branch_cand.items()})
    names.update(overrides or {})
    return names


def window_bounds(weeks):
    now = dt.datetime.now().astimezone()
    today = now.date()
    monday = today - dt.timedelta(days=today.weekday())
    start_date = monday - dt.timedelta(days=(weeks - 1) * 7)
    start_dt = dt.datetime.combine(start_date, dt.time.min).astimezone()
    return start_dt, now, start_date, today


_WT_ROOT_CACHE = {}


def worktree_root(cwd):
    """Normalise a cwd to its git worktree root, so a session run from a deep
    subdirectory (e.g. .../AdjustmentsDialog/components) folds into the worktree's
    lane instead of spawning its own. Walks up to the nearest ancestor holding a
    .git entry — worktrees carry a .git *file*, the main repo a .git *dir*. A
    worktree since deleted off disk falls back to the cwd unchanged."""
    if cwd in _WT_ROOT_CACHE:
        return _WT_ROOT_CACHE[cwd]
    home = HOME.resolve()
    cur = Path(cwd)
    found = None
    while True:
        try:
            if (cur / ".git").exists():
                found = str(cur)
                break
        except OSError:
            break
        if cur == cur.parent or cur == home:
            break
        cur = cur.parent
    root = found or cwd
    _WT_ROOT_CACHE[cwd] = root
    return root


def lane_meta(cwd, app_paths):
    """Build a stable lane descriptor for a working directory."""
    cwd = worktree_root(cwd)
    p = cwd.rstrip("/")
    is_app = any(p == a.rstrip("/") for a in app_paths)
    parts = p.split("/")
    # nice label: for ~/dev/cmr-web-ralph/pbl-7198 -> "cmr-web-ralph/pbl-7198"
    label = "/".join(parts[-2:]) if len(parts) >= 2 else p
    repo = parts[-1]
    return {"id": p, "path": p, "label": label, "repo": repo, "isApp": is_app}


def collect_prompts(start_dt, end_dt, app_paths):
    """Human-typed Claude prompts: type==user, promptSource==typed."""
    events = []
    lanes = {}
    if not CLAUDE_PROJECTS.exists():
        return events, lanes
    start_epoch = start_dt.timestamp()
    for fp in glob.glob(str(CLAUDE_PROJECTS / "*" / "*.jsonl")):
        # cheap skip: file untouched before the window can't hold in-window events
        try:
            if os.path.getmtime(fp) < start_epoch:
                continue
        except OSError:
            continue
        with open(fp, "r", errors="replace") as fh:
            for line in fh:
                if '"typed"' not in line:
                    continue
                try:
                    d = json.loads(line)
                except Exception:
                    continue
                if d.get("type") != "user" or d.get("promptSource") != "typed":
                    continue
                local = to_local(d.get("timestamp"))
                if not local or not (start_dt <= local <= end_dt):
                    continue
                cwd = d.get("cwd")
                if not cwd:
                    continue
                msg = d.get("message") or {}
                c = msg.get("content") if isinstance(msg, dict) else None
                preview = " ".join(c.split())[:90] if isinstance(c, str) else None
                lm = lane_meta(cwd, app_paths)
                lanes[lm["id"]] = lm
                events.append({
                    "date": local.date().isoformat(),
                    "minute": minute_of(local),
                    "ts": local.isoformat(),
                    "lane": lm["id"],
                    "jira": jira_from(d.get("gitBranch")),
                    "branch": d.get("gitBranch"),
                    "type": "prompt",
                    "preview": preview,
                })
    return events, lanes


def collect_checkouts(start_dt, end_dt, app_paths):
    """gco/gcod wrapper log lines: <epoch>\t<cwd>\t<branch>\t<action>."""
    events = []
    lanes = {}
    if not GCOD_LOG.exists():
        return events, lanes
    for line in GCOD_LOG.read_text(errors="replace").splitlines():
        parts = line.split("\t")
        if len(parts) < 4:
            continue
        epoch, cwd, branch, action = parts[0], parts[1], parts[2], parts[3]
        try:
            local = dt.datetime.fromtimestamp(int(epoch)).astimezone()
        except (ValueError, OverflowError):
            continue
        if not (start_dt <= local <= end_dt) or not cwd:
            continue
        lm = lane_meta(cwd, app_paths)
        lanes[lm["id"]] = lm
        events.append({
            "date": local.date().isoformat(),
            "minute": minute_of(local),
            "ts": local.isoformat(),
            "lane": lm["id"],
            "jira": jira_from(branch),
            "branch": branch or None,
            "type": action if action in ("gco", "gcod") else "checkout",
        })
    return events, lanes


# ------------------------- calendar (ICS) -------------------------
WD = {"MO": 0, "TU": 1, "WE": 2, "TH": 3, "FR": 4, "SA": 5, "SU": 6}


def fetch_ics(url, timeout=20):
    # 5-min cache so repeated regenerates don't re-hit the network every time
    try:
        if ICS_CACHE.exists() and time.time() - ICS_CACHE.stat().st_mtime < 300:
            return ICS_CACHE.read_text()
    except OSError:
        pass
    req = urllib.request.Request(url, headers={"User-Agent": "timetrack"})
    with urllib.request.urlopen(req, timeout=timeout) as r:
        text = r.read().decode("utf-8", "replace")
    try:
        CACHE_DIR.mkdir(parents=True, exist_ok=True)
        ICS_CACHE.write_text(text)
    except OSError:
        pass
    return text


def unfold(text):
    """RFC5545 line unfolding: a leading space/tab continues the previous line."""
    out = []
    for line in text.splitlines():
        if line[:1] in (" ", "\t") and out:
            out[-1] += line[1:]
        else:
            out.append(line)
    return out


def parse_vevents(lines):
    """Collect VEVENT property dicts, skipping VTIMEZONE (its DST rules are not meetings)."""
    events, cur, in_tz = [], None, False
    for ln in lines:
        if ln == "BEGIN:VTIMEZONE":
            in_tz = True; continue
        if ln == "END:VTIMEZONE":
            in_tz = False; continue
        if in_tz:
            continue
        if ln == "BEGIN:VEVENT":
            cur = {}; continue
        if ln == "END:VEVENT":
            if cur is not None:
                events.append(cur); cur = None
            continue
        if cur is None or ":" not in ln:
            continue
        name_params, _, val = ln.partition(":")
        bits = name_params.split(";")
        name = bits[0].upper()
        params = {}
        for p in bits[1:]:
            if "=" in p:
                k, v = p.split("=", 1)
                params[k.upper()] = v
        if name in ("DTSTART", "DTEND"):
            cur[name] = (val, params)
        elif name == "EXDATE":
            cur.setdefault("EXDATE", []).append((val, params))
        else:
            cur[name] = val
    return events


def ics_unescape(s):
    out = s.replace("\\\\", "\x00").replace("\\n", " ").replace("\\N", " ").replace("\\,", ",").replace("\\;", ";")
    return " ".join(out.replace("\x00", "\\").split())


def parse_ics_dt(value, params=None):
    """Return (local-aware datetime, is_all_day). TZID times are treated as local
    wall-clock (machine is NZ); Z values are converted from UTC."""
    params = params or {}
    v = value.strip()
    if params.get("VALUE") == "DATE" or (len(v) == 8 and "T" not in v):
        return dt.datetime.strptime(v, "%Y%m%d").astimezone(), True
    if v.endswith("Z"):
        return dt.datetime.strptime(v, "%Y%m%dT%H%M%SZ").replace(tzinfo=dt.timezone.utc).astimezone(), False
    return dt.datetime.strptime(v[:15], "%Y%m%dT%H%M%S").astimezone(), False


def nth_weekday(year, month, wd, nth):
    """nth (1-based, or -1 for last) weekday `wd` in a given month."""
    if nth > 0:
        d = dt.date(year, month, 1)
        d += dt.timedelta(days=(wd - d.weekday()) % 7)
        d += dt.timedelta(weeks=nth - 1)
        return d if d.month == month else None
    # last
    if month == 12:
        d = dt.date(year, 12, 31)
    else:
        d = dt.date(year, month + 1, 1) - dt.timedelta(days=1)
    d -= dt.timedelta(days=(d.weekday() - wd) % 7)
    return d


def expand_rrule(start_dt, rrule, win_end):
    """Expand a recurrence to local-aware occurrence datetimes up to win_end (date)."""
    parts = dict(p.split("=", 1) for p in rrule.split(";") if "=" in p)
    freq = parts.get("FREQ")
    interval = int(parts.get("INTERVAL", "1") or 1)
    count = int(parts["COUNT"]) if "COUNT" in parts else None
    until = None
    if "UNTIL" in parts:
        try:
            until = parse_ics_dt(parts["UNTIL"])[0].date()
        except Exception:
            until = None
    byday = parts.get("BYDAY")
    t = start_dt.timetz()
    stop = min(until, win_end) if until else win_end
    occ, n, guard = [], 0, 0

    def keep(cand):
        nonlocal n
        occ.append(cand)
        n += 1
        return not (count and n >= count)

    if freq == "WEEKLY":
        days = sorted(WD[d[-2:]] for d in byday.split(",")) if byday else [start_dt.weekday()]
        week = start_dt.date() - dt.timedelta(days=start_dt.weekday())
        while week <= stop and guard < 1500:
            guard += 1
            for wd in days:
                d = week + dt.timedelta(days=wd)
                if d < start_dt.date() or d > stop:
                    continue
                if not keep(dt.datetime.combine(d, t)):
                    return occ
            week += dt.timedelta(weeks=interval)
    elif freq == "DAILY":
        d = start_dt
        while d.date() <= stop and guard < 3000:
            guard += 1
            if not keep(d):
                return occ
            d += dt.timedelta(days=interval)
    elif freq == "MONTHLY":
        bymd = parts.get("BYMONTHDAY")
        y, mo = start_dt.year, start_dt.month
        while guard < 400:
            guard += 1
            cand_date = None
            if bymd:
                try:
                    cand_date = dt.date(y, mo, int(bymd.split(",")[0]))
                except ValueError:
                    cand_date = None
            elif byday:
                m = re.match(r"(-?\d+)([A-Z]{2})", byday.split(",")[0])
                if m:
                    cand_date = nth_weekday(y, mo, WD[m.group(2)], int(m.group(1)))
            else:
                try:
                    cand_date = dt.date(y, mo, start_dt.day)
                except ValueError:
                    cand_date = None
            if cand_date and cand_date >= start_dt.date():
                if cand_date > stop:
                    break
                if not keep(dt.datetime.combine(cand_date, t)):
                    return occ
            mo += interval
            while mo > 12:
                mo -= 12; y += 1
    else:
        occ = [start_dt]  # unknown/unsupported freq → just the base occurrence
    return occ


def expand_meeting(ev, win_start, win_end):
    if "DTSTART" not in ev:
        return []
    start_dt, all_day = parse_ics_dt(*ev["DTSTART"])
    if all_day:
        return []  # all-day events don't paint the working-hours timeline
    if "DTEND" in ev:
        dur = parse_ics_dt(*ev["DTEND"])[0] - start_dt
    else:
        dur = dt.timedelta(minutes=30)
    title = ics_unescape(ev.get("SUMMARY") or "(no title)")
    status = ev.get("STATUS", "")
    busy = ev.get("X-MICROSOFT-CDO-BUSYSTATUS", "")
    # datetime-valued EXDATEs match one exact occurrence, so a cancelled morning
    # slot doesn't nuke a same-day afternoon one; DATE-valued EXDATEs (all-day
    # exceptions) still knock out the whole day.
    ex_dts, ex_dates = set(), set()
    for val, params in ev.get("EXDATE", []):
        for piece in val.split(","):
            try:
                exd, ex_all_day = parse_ics_dt(piece, params)
                if ex_all_day:
                    ex_dates.add(exd.date())
                else:
                    ex_dts.add(exd)
            except Exception:
                pass
    starts = expand_rrule(start_dt, ev["RRULE"], win_end) if ev.get("RRULE") else [start_dt]
    out = []
    for s in starts:
        if s in ex_dts or s.date() in ex_dates or not (win_start <= s.date() <= win_end) or s.weekday() >= 5:
            continue
        e = s + dur
        out.append({
            "date": s.date().isoformat(),
            "startMin": s.hour * 60 + s.minute,
            "endMin": (e.hour * 60 + e.minute) if e.date() == s.date() else 24 * 60,
            "title": title, "busy": busy, "status": status,
        })
    return out


def collect_holidays(cfg, start_date, today):
    """NZ public holidays from the (free, keyless) Nager.Date API, for every year
    in the window. National holidays always count; provincial anniversary days
    only if they match `holiday_region`. Cached on disk with a 7-day TTL — near
    static, but one-off additions (e.g. a memorial day) do happen. Returns
    {date: name}."""
    region = cfg.get("holiday_region")
    code = NZ_REGIONS.get(region) if region else None
    years = sorted({start_date.year, today.year})

    cache = {}
    if HOLIDAYS_CACHE.exists():
        try:
            cache = json.loads(HOLIDAYS_CACHE.read_text())
        except (OSError, json.JSONDecodeError):
            cache = {}

    changed = False
    out = {}
    for y in years:
        entry = cache.get(str(y))
        if not entry or (time.time() - entry.get("fetched", 0) > 7 * 86400):
            try:
                req = urllib.request.Request(
                    f"https://date.nager.at/api/v3/PublicHolidays/{y}/NZ",
                    headers={"User-Agent": "timetrack"})
                with urllib.request.urlopen(req, timeout=15) as r:
                    items = json.loads(r.read().decode("utf-8", "replace"))
                entry = {"fetched": int(time.time()), "items": items}
                cache[str(y)] = entry
                changed = True
            except Exception as e:
                print(f"warning: holiday fetch failed for {y}: {e}", file=sys.stderr)
                entry = entry or {"items": []}
        for h in entry.get("items", []):
            national = h.get("global", False) or not h.get("counties")
            if national or (code and code in (h.get("counties") or [])):
                out[h["date"]] = h.get("localName") or h.get("name")

    if changed:
        try:
            CACHE_DIR.mkdir(parents=True, exist_ok=True)
            HOLIDAYS_CACHE.write_text(json.dumps(cache))
        except OSError:
            pass
    return out


def collect_meetings(cfg, start_date, today):
    url = cfg.get("ics_url")
    if not url:
        return []
    try:
        events = parse_vevents(unfold(fetch_ics(url)))
    except Exception as e:
        print(f"warning: calendar fetch/parse failed: {e}", file=sys.stderr)
        return []
    skip = [s.lower() for s in cfg.get("skip_meetings", [])]
    meetings, seen = [], set()
    for ev in events:
        for m in expand_meeting(ev, start_date, today):
            m["id"] = f'{m["date"]}|{m["startMin"]}|{m["title"]}'
            if m["id"] in seen:
                continue
            seen.add(m["id"])
            tl = m["title"].lower()
            m["defaultOn"] = (m["busy"] != "FREE" and m["status"] != "CANCELLED"
                              and not tl.startswith("canceled:") and not tl.startswith("cancelled:")
                              and not any(s in tl for s in skip))
            meetings.append(m)
    meetings.sort(key=lambda m: (m["date"], m["startMin"]))
    return meetings


# A review only counts once you've dwelled: a session is consecutive ticks on
# the same JIRA (gaps <= SESSION_GAP); sessions with fewer than MIN_TICKS ticks
# are fly-by glances and get dropped. Raw ticks stay in the log so the
# threshold can be retuned later.
SESSION_GAP = 300   # seconds; ticks are ~75s apart
MIN_TICKS = 2


def collect_reviews(start_dt, end_dt):
    """GitHub PR review heartbeat ticks: <epoch>\t<jira>\t<url>\t<title>\t<branch>.
    Returns (events, lane, meta) — meta maps each reviewed jira to the PR title,
    author and url for the legend popover. The branch (5th field, absent on older
    log lines) names the review lane via the same slug rule as worktree branches."""
    if not REVIEW_LOG.exists():
        return [], {}, {}
    raw = []
    for line in REVIEW_LOG.read_text(errors="replace").splitlines():
        parts = line.split("\t")
        if not parts or not parts[0]:
            continue
        try:
            epoch = int(parts[0])
        except ValueError:
            continue
        jira = parts[1] if len(parts) > 1 else ""
        url = parts[2] if len(parts) > 2 else ""
        title = parts[3] if len(parts) > 3 else ""
        branch = parts[4] if len(parts) > 4 and parts[4] else None
        local = dt.datetime.fromtimestamp(epoch).astimezone()
        if not (start_dt <= local <= end_dt):
            continue
        raw.append({"epoch": epoch, "local": local,
                    "jira": jira or jira_from(branch) or jira_from(title) or jira_from(url),
                    "title": title, "url": url, "branch": branch})
    raw.sort(key=lambda t: t["epoch"])

    # group into dwell sessions, keep only those with >= MIN_TICKS ticks
    events = []
    meta = {}
    i = 0
    while i < len(raw):
        j = i + 1
        while (j < len(raw) and raw[j]["epoch"] - raw[j - 1]["epoch"] <= SESSION_GAP
               and raw[j]["jira"] == raw[i]["jira"]):
            j += 1
        if j - i >= MIN_TICKS:
            pr_title, author = parse_review_title(raw[j - 1]["title"])
            for t in raw[i:j]:
                jira = t["jira"] or None
                lc = t["local"]
                events.append({
                    "date": lc.date().isoformat(),
                    "minute": minute_of(lc),
                    "ts": lc.isoformat(),
                    "lane": REVIEW_LANE,
                    "jira": jira,
                    "branch": t["branch"],
                    "type": "review",
                    "preview": pr_title or t["title"] or t["url"],
                })
            jira = raw[j - 1]["jira"] or None
            if jira:  # most recent session's PR details win, for the popover
                meta[jira] = {"title": pr_title or raw[j - 1]["title"],
                              "author": author, "url": raw[j - 1]["url"]}
        i = j

    lane = {REVIEW_LANE: {"id": REVIEW_LANE, "path": REVIEW_LANE, "label": "GitHub review",
                          "repo": "review", "isApp": False, "isReview": True}} if events else {}
    return events, lane, meta


# A focus dwell is a run of consecutive same-lane ticks with NO signal from a
# different lane interrupting it — a prompt/checkout/review on another lane is
# proof you'd moved on, so it breaks the run (the run resumes on the next tick).
# There is no max time gap: if nothing else fired, two same-lane ticks bridge
# however far apart they are — "no competing signal, so you were on that ticket"
# is the best available guess.
#
# A run is kept if it spans >= MIN_DWELL_SEC, OR if a deliberate same-lane signal
# (a prompt / checkout) lands inside it — typing in a worktree is hard proof you
# were there, so it promotes even a single focus tick into real attention. Only a
# bare lone tick with nothing to back it up is dropped as a fly-by.
MIN_DWELL_SEC = 30


def collect_focus(start_dt, end_dt, app_paths, other_events):
    """iTerm2 focus ticks: <epoch>\t<cwd>\t<branch>. Groups consecutive same-lane
    ticks into dwell runs — broken by any signal on a different lane — and emits
    the runs that span >= MIN_DWELL_SEC as focus events on the worktree lane."""
    events = []
    lanes = {}
    if not FOCUS_LOG.exists():
        return events, lanes

    ticks = []
    for line in FOCUS_LOG.read_text(errors="replace").splitlines():
        parts = line.split("\t")
        if len(parts) < 2 or not parts[0] or not parts[1]:
            continue
        try:
            epoch = int(parts[0])
        except ValueError:
            continue
        cwd = parts[1]
        branch = parts[2] if len(parts) > 2 and parts[2] else None
        local = dt.datetime.fromtimestamp(epoch).astimezone()
        if not (start_dt <= local <= end_dt):
            continue
        lm = lane_meta(cwd, app_paths)
        ticks.append({"epoch": epoch, "local": local, "lm": lm, "lane": lm["id"],
                      "branch": branch})
    if not ticks:
        return events, lanes

    # Merge focus ticks with the other signals as a single time-ordered stream;
    # a signal on a different lane breaks the current dwell run. kind 0 = focus
    # tick, kind 1 = other signal (sorts after a same-instant tick).
    markers = [(t["epoch"], 0, t) for t in ticks]
    for e in other_events:
        d = to_local(e["ts"])
        if d:
            markers.append((d.timestamp(), 1, e["lane"]))
    markers.sort(key=lambda m: (m[0], m[1]))

    run = []        # focus ticks of the current run (all on run_lane)
    run_lane = None
    corroborated = False   # a same-lane prompt/checkout landed inside this run

    def flush():
        nonlocal run, run_lane, corroborated
        span = run[-1]["epoch"] - run[0]["epoch"] if run else 0
        if run and (span >= MIN_DWELL_SEC or corroborated):
            for t in run:
                lanes[t["lane"]] = t["lm"]
                lc = t["local"]
                events.append({
                    "date": lc.date().isoformat(),
                    "minute": minute_of(lc),
                    "ts": lc.isoformat(),
                    "lane": t["lane"],
                    "jira": jira_from(t["branch"]),
                    "branch": t["branch"],
                    "type": "focus",
                    "preview": None,
                })
        run = []
        run_lane = None
        corroborated = False

    for _, kind, payload in markers:
        if kind == 0:  # focus tick
            t = payload
            if run_lane is None or t["lane"] == run_lane:
                run.append(t)
                run_lane = t["lane"]
            else:  # focus jumped to another lane — close the old run, open a new one
                flush()
                run = [t]
                run_lane = t["lane"]
        elif run_lane is not None:  # a deliberate signal (payload = its lane)
            if payload == run_lane:
                corroborated = True   # typing here proves the focus tick was real
            else:
                flush()               # moved to a different ticket — run ends
    flush()
    return events, lanes


def build_weeks(start_date, today):
    """Mon–Fri columns per ISO week across the window."""
    weeks = []
    monday = start_date - dt.timedelta(days=start_date.weekday())
    cur_monday = today - dt.timedelta(days=today.weekday())
    while monday <= cur_monday:
        days = []
        for i in range(5):  # Mon..Fri
            d = monday + dt.timedelta(days=i)
            days.append({
                "date": d.isoformat(),
                "weekday": d.strftime("%A"),
                "short": d.strftime("%a %-d %b"),
                "isToday": d == today,
            })
        iso_year, iso_week, _ = monday.isocalendar()
        weeks.append({
            "iso": f"{iso_year}-W{iso_week:02d}",
            "label": f"{monday.strftime('%-d %b')} – {(monday + dt.timedelta(days=4)).strftime('%-d %b')}",
            "monday": monday.isoformat(),
            "isCurrent": monday == cur_monday,
            "days": days,
        })
        monday += dt.timedelta(days=7)
    return weeks


def trim_logs(cfg, keep_from):
    """Drop tick-log lines older than `log_retain_weeks` weeks so the logs can't
    grow forever (0/null = never trim). Never trims into the window the current
    build is scanning; lines with no parseable epoch are kept. A file is only
    rewritten once its oldest line is a full week past the cutoff, so the (tiny)
    race with a daemon appending mid-rewrite is a weekly event, not a per-build
    one — and losing means one ~30s tick, not a session."""
    try:
        retain = int(cfg.get("log_retain_weeks") or 0)
    except (ValueError, TypeError):
        retain = 0
    if retain <= 0:
        return
    now = dt.datetime.now().astimezone()
    cutoff = min(now - dt.timedelta(weeks=retain), keep_from).timestamp()

    def epoch_of(line):
        head = line.split("\t", 1)[0].strip()
        return int(head) if head.isdigit() else None

    for path in (GCOD_LOG, REVIEW_LOG, FOCUS_LOG):
        if not path.exists():
            continue
        try:
            lines = path.read_text(errors="replace").splitlines(keepends=True)
        except OSError:
            continue
        oldest = next((e for e in map(epoch_of, lines) if e is not None), None)
        if oldest is None or oldest >= cutoff - 7 * 86400:
            continue
        kept = []
        for ln in lines:
            e = epoch_of(ln)
            if e is None or e >= cutoff:
                kept.append(ln)
        tmp = path.with_suffix(path.suffix + ".tmp")
        try:
            tmp.write_text("".join(kept))
            os.replace(tmp, path)
        except OSError as e:
            print(f"warning: could not trim {path}: {e}", file=sys.stderr)


def build_blob(weeks=None):
    """Re-derive everything from the signal sources and return the data blob.
    weeks=None means "use the config default", so a Settings edit to it applies."""
    cfg = load_config()
    app_paths = cfg["app_paths"]
    if weeks is None:
        try:
            weeks = int(cfg.get("weeks") or DEFAULTS["weeks"])
        except (ValueError, TypeError):
            weeks = DEFAULTS["weeks"]
    start_dt, end_dt, start_date, today = window_bounds(weeks)
    trim_logs(cfg, start_dt)

    p_events, p_lanes = collect_prompts(start_dt, end_dt, app_paths)
    c_events, c_lanes = collect_checkouts(start_dt, end_dt, app_paths)
    r_events, r_lanes, r_meta = collect_reviews(start_dt, end_dt)
    # focus dwell is broken by any other-lane signal, so it needs the rest first
    f_events, f_lanes = collect_focus(start_dt, end_dt, app_paths,
                                      p_events + c_events + r_events)

    lanes = {**p_lanes, **c_lanes, **r_lanes, **f_lanes}
    events = sorted(p_events + c_events + r_events + f_events, key=lambda e: e["ts"])

    return {
        "generatedAt": end_dt.isoformat(),
        "tz": str(end_dt.tzinfo),
        "window": {
            "start": start_dt.date().isoformat(),
            "end": today.isoformat(),
            "weeks": weeks,
        },
        "frame": {
            "startMin": hhmm_to_min(cfg.get("day_start"), 8 * 60),
            "endMin": hhmm_to_min(cfg.get("day_end"), 17 * 60),
            "idleTailMin": int(cfg.get("idle_tail_min") or DEFAULTS["idle_tail_min"]),
        },
        "timesheet": {
            "fullDayMin": hhmm_to_min(cfg.get("full_day"), 450),
            "roundToMin": int(cfg.get("round_to_min") or DEFAULTS["round_to_min"]),
        },
        "lanes": lanes,
        "events": events,
        "jiraNames": build_jira_names(events, cfg.get("jira_names")),
        "jiraCodes": cfg.get("jira_codes") or {},
        "reviewMeta": r_meta,
        "meetings": collect_meetings(cfg, start_date, today),
        "holidays": collect_holidays(cfg, start_date, today),
        "holidayRegion": cfg.get("holiday_region"),
        "weeks": build_weeks(start_date, today),
        "config": {"appPaths": app_paths, "skipMeetings": cfg["skip_meetings"],
                   "regions": sorted(NZ_REGIONS),
                   "logRetainWeeks": cfg.get("log_retain_weeks", DEFAULTS["log_retain_weeks"])},
    }


def read_raw_config():
    """config.json exactly as written on disk (no DEFAULTS merged), {} if missing/bad."""
    if CONFIG_PATH.exists():
        try:
            return json.loads(CONFIG_PATH.read_text())
        except (OSError, json.JSONDecodeError):
            pass
    return {}


def write_raw_config(cfg):
    CONFIG_PATH.write_text(json.dumps(cfg, indent=2) + "\n")


def update_config(updates):
    """Merge whitelisted preference keys into config.json (preserving the rest).
    Coerces the minute/week fields to int; ignores anything not editable."""
    cfg = read_raw_config()
    for k, v in (updates or {}).items():
        if k not in EDITABLE_KEYS:
            continue
        if k in ("idle_tail_min", "round_to_min", "weeks", "log_retain_weeks"):
            try:
                v = int(v)
            except (ValueError, TypeError):
                continue
        elif k == "skip_meetings":
            if not isinstance(v, list):
                continue
            v = [s.strip() for s in v if isinstance(s, str) and s.strip()]
        cfg[k] = v
    write_raw_config(cfg)
    return cfg


def set_jira_code(jira, code):
    """Persist one JIRA -> timesheet-code mapping in config.json. An empty code
    unsets the mapping. Preserves the rest of the file."""
    cfg = read_raw_config()
    codes = dict(cfg.get("jira_codes") or {})
    code = (code or "").strip()
    if code:
        codes[jira] = code
    else:
        codes.pop(jira, None)
    cfg["jira_codes"] = codes
    write_raw_config(cfg)
    return codes


def remove_jira_code(code):
    """Drop a whole timesheet code: unmap every JIRA currently pointing at it."""
    cfg = read_raw_config()
    cfg["jira_codes"] = {j: c for j, c in (cfg.get("jira_codes") or {}).items() if c != code}
    write_raw_config(cfg)
    return cfg["jira_codes"]


def render_html(blob):
    payload = "window.__TIMETRACK__ = " + json.dumps(blob) + ";"
    return TEMPLATE.read_text().replace("/*__TIMETRACK_DATA__*/", payload)


def write_out(weeks=None):
    """Build + render + write out/timetrack.html. Returns the blob."""
    blob = build_blob(weeks)
    OUT.parent.mkdir(parents=True, exist_ok=True)
    OUT.write_text(render_html(blob))
    return blob


# ------------------------- serve / daemon -------------------------

def _read_pidfile():
    try:
        parts = PID_FILE.read_text().split()
        return int(parts[0]), (int(parts[1]) if len(parts) > 1 else DEFAULT_PORT)
    except (OSError, ValueError, IndexError):
        return None, None


def _alive(pid):
    try:
        os.kill(pid, 0)
        return True
    except OSError:
        return False


def _port_up(port, timeout=4.0):
    """True once the port accepts a connection, else False after timeout."""
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        try:
            with socket.create_connection(("127.0.0.1", port), 0.2):
                return True
        except OSError:
            time.sleep(0.1)
    return False


def _open_browser(port):
    """Open the browser once the server is listening. Only usable while this
    process stays alive (foreground serve) — a backgrounded start exits too soon,
    so it tells the user to run --open instead."""
    def go():
        if _port_up(port):
            os.system(f"open http://localhost:{port}")
    threading.Thread(target=go, daemon=True).start()


ITERM_AUTOLAUNCH = (HOME / "Library" / "Application Support" / "iTerm2"
                    / "Scripts" / "AutoLaunch" / "timetrack-focus.py")
# Chromium-family app-support dirs the review host is registered into (mirrors
# extension/install-host.sh), mapped to friendly names for the Setup panel.
BROWSER_DIRS = [
    ("Google/Chrome", "Chrome"),
    ("Google/Chrome Canary", "Chrome Canary"),
    ("Arc/User Data", "Arc"),
    ("BraveSoftware/Brave-Browser", "Brave"),
    ("Microsoft Edge", "Edge"),
    ("Chromium", "Chromium"),
]


def _last_tick_epoch(logpath):
    """Epoch of the most recent line in a tab-separated tick log, or None."""
    if not logpath.exists():
        return None
    last = None
    try:
        for line in logpath.read_text(errors="replace").splitlines():
            head = line.split("\t", 1)[0]
            if head.isdigit():
                last = int(head)
    except OSError:
        return None
    return last


def setup_status():
    """Live state of the two integrations, for the served Setup panel."""
    try:
        running = subprocess.run(["pgrep", "-f", "timetrack-focus.py"],
                                 capture_output=True).returncode == 0
    except OSError:
        running = False
    browsers = [name for d, name in BROWSER_DIRS
                if (HOME / "Library" / "Application Support" / d
                    / "NativeMessagingHosts" / "com.timetrack.review.json").exists()]
    return {
        "focus": {"linked": ITERM_AUTOLAUNCH.exists(), "running": running,
                  "lastTick": _last_tick_epoch(FOCUS_LOG)},
        "review": {"registered": bool(browsers), "browsers": browsers,
                   "lastTick": _last_tick_epoch(REVIEW_LOG)},
    }


def _run_installer(args):
    """Run an install script and return {ok, out} (combined output, tail)."""
    try:
        r = subprocess.run(args, capture_output=True, text=True, timeout=30,
                           cwd=str(Path(__file__).resolve().parent.parent))
        return {"ok": r.returncode == 0, "out": (r.stdout + r.stderr).strip()[-1500:]}
    except Exception as e:
        return {"ok": False, "out": str(e)}


def install_focus_daemon():
    return _run_installer(["bash", str(Path(__file__).resolve().parent / "install-focus-daemon.sh")])


def install_review_host(ext_id):
    if not re.fullmatch(r"[a-p]{32}", ext_id or ""):
        return {"ok": False, "out": "that doesn't look like a Chrome extension id (32 letters a–p)"}
    return _run_installer(["bash", str(Path(__file__).resolve().parent.parent / "extension" / "install-host.sh"), ext_id])


def _serve(weeks, port, open_browser=True):
    """Foreground HTTP server. GET / serves the last build; GET /regenerate
    re-greps the sources and rewrites it, for the in-page Regenerate button."""
    import http.server
    import socketserver

    write_out(weeks)  # initial build

    class Handler(http.server.BaseHTTPRequestHandler):
        def log_message(self, *a):
            pass  # quiet; the access log isn't useful here

        def _send(self, code, body, ctype):
            self.send_response(code)
            self.send_header("Content-Type", ctype)
            self.send_header("Content-Length", str(len(body)))
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            if self.command != "HEAD":
                self.wfile.write(body)

        def _origin_ok(self):
            """Browsers attach Origin to cross-site requests: a page on some other
            site must not be able to drive this server. Absent header (same-origin
            GET, curl) is fine."""
            origin = self.headers.get("Origin")
            return not origin or origin in (f"http://localhost:{port}",
                                            f"http://127.0.0.1:{port}")

        def _json_body(self):
            n = int(self.headers.get("Content-Length", 0))
            return json.loads(self.rfile.read(n) or b"{}")

        def _api(self, fn):
            """Run fn() -> dict and send it as JSON; any exception becomes a 500.
            `out` mirrors `error` because the Setup panel reads j.out."""
            if not self._origin_ok():
                self._send(403, b"forbidden", "text/plain")
                return
            try:
                self._send(200, json.dumps(fn()).encode(), "application/json")
            except Exception as e:
                self._send(500, json.dumps({"ok": False, "error": str(e), "out": str(e)}).encode(),
                           "application/json")

        def do_GET(self):
            path = self.path.split("?", 1)[0]
            if path in ("/", "/index.html"):
                try:
                    self._send(200, OUT.read_bytes(), "text/html; charset=utf-8")
                except OSError:
                    self._send(500, b"build missing", "text/plain")
            elif path == "/regenerate":
                self._api(lambda: {"ok": True, "events": len(write_out(weeks)["events"])})
            elif path == "/setup-status":
                self._api(setup_status)
            else:
                self._send(404, b"not found", "text/plain")

        def do_POST(self):
            path = self.path.split("?", 1)[0]
            if path == "/config":
                def save_and_rebuild():
                    update_config(self._json_body())     # merge + write config.json
                    blob = write_out(weeks)              # rebuild with the new settings
                    return {"ok": True, "events": len(blob["events"])}
                self._api(save_and_rebuild)
            elif path == "/jira-code":
                def set_code():
                    body = self._json_body()
                    set_jira_code(body.get("jira", ""), body.get("code", ""))
                    write_out(weeks)                     # re-bake so a hard refresh stays in sync
                    return {"ok": True}
                self._api(set_code)
            elif path == "/remove-code":
                def rm_code():
                    remove_jira_code(self._json_body().get("code", ""))
                    write_out(weeks)
                    return {"ok": True}
                self._api(rm_code)
            elif path == "/setup/install-focus":
                self._api(install_focus_daemon)
            elif path == "/setup/install-host":
                self._api(lambda: install_review_host(self._json_body().get("id", "")))
            else:
                self._send(404, b"not found", "text/plain")

    socketserver.ThreadingTCPServer.allow_reuse_address = True
    try:
        httpd = socketserver.ThreadingTCPServer(("127.0.0.1", port), Handler)
    except OSError as e:
        print(f"could not bind port {port}: {e}", file=sys.stderr)
        sys.exit(1)
    if open_browser:
        _open_browser(port)
    print(f"timetrack serving on http://localhost:{port}  (Ctrl-C to stop)")
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        pass
    finally:
        httpd.server_close()


def serve_start(weeks, port, daemon):
    pid, oldport = _read_pidfile()
    if pid and _alive(pid):
        print(f"already serving (pid {pid}) on http://localhost:{oldport}  (open it with --open)")
        return
    PID_FILE.parent.mkdir(parents=True, exist_ok=True)
    if daemon:
        logf = open(SERVE_LOG, "a")
        cmd = [sys.executable, os.path.abspath(__file__), "--_serve-run", "--port", str(port)]
        if weeks is not None:   # else the child stays config-driven, so Settings edits to it apply
            cmd += ["--weeks", str(weeks)]
        proc = subprocess.Popen(
            cmd, stdout=logf, stderr=logf, stdin=subprocess.DEVNULL, start_new_session=True,
        )
        PID_FILE.write_text(f"{proc.pid} {port}\n")
        if _port_up(port):
            print(f"timetrack serving in background (pid {proc.pid}) on http://localhost:{port}")
            print(f"  open: {Path(__file__).name} --open")
            print(f"  stop: {Path(__file__).name} --stop")
        else:
            print(f"server didn't come up on port {port} — see {SERVE_LOG}", file=sys.stderr)
            PID_FILE.unlink(missing_ok=True)
    else:
        PID_FILE.write_text(f"{os.getpid()} {port}\n")
        try:
            _serve(weeks, port)
        finally:
            if _read_pidfile()[0] == os.getpid():
                PID_FILE.unlink(missing_ok=True)


def serve_open():
    pid, port = _read_pidfile()
    if pid and _alive(pid):
        os.system(f"open http://localhost:{port}")
    else:
        print("not running — start it with --daemon (or --serve)")


def serve_stop():
    pid, port = _read_pidfile()
    if not pid or not _alive(pid):
        print("not running")
        PID_FILE.unlink(missing_ok=True)
        return
    try:
        os.kill(pid, signal.SIGTERM)
        print(f"stopped (pid {pid})")
    except OSError as e:
        print(f"could not stop pid {pid}: {e}", file=sys.stderr)
    PID_FILE.unlink(missing_ok=True)


def serve_status():
    pid, port = _read_pidfile()
    if pid and _alive(pid):
        print(f"running (pid {pid}) on http://localhost:{port}")
    else:
        print("not running")


def main():
    ap = argparse.ArgumentParser(description="Build the timetrack visual.")
    ap.add_argument("-w", "--weeks", type=int, default=None,
                    help="number of weeks to scan, ending this week (default: config `weeks`, or 4)")
    ap.add_argument("--json", action="store_true", help="print JSON to stdout, don't write HTML")
    ap.add_argument("--serve", action="store_true",
                    help="serve on http://localhost with a Regenerate button (foreground)")
    ap.add_argument("--daemon", action="store_true",
                    help="like --serve but in the background; stop it with --stop")
    ap.add_argument("--stop", action="store_true", help="stop a background server")
    ap.add_argument("--open", action="store_true", help="open the running server in your browser")
    ap.add_argument("--status", action="store_true", help="report whether a background server is running")
    ap.add_argument("--port", type=int, default=DEFAULT_PORT,
                    help=f"port for --serve/--daemon (default {DEFAULT_PORT})")
    ap.add_argument("--_serve-run", dest="serve_run", action="store_true", help=argparse.SUPPRESS)
    args = ap.parse_args()

    if args.serve_run:        # internal: the backgrounded child runs the server
        _serve(args.weeks, args.port, open_browser=False)
        return
    if args.stop:
        serve_stop()
        return
    if args.open:
        serve_open()
        return
    if args.status:
        serve_status()
        return
    if args.serve or args.daemon:
        serve_start(args.weeks, args.port, daemon=args.daemon)
        return

    if args.json:
        print(json.dumps(build_blob(args.weeks), indent=2))
        return
    if not TEMPLATE.exists():
        print(json.dumps(build_blob(args.weeks), indent=2))
        print(f"\n(no template at {TEMPLATE} yet — printed JSON instead)", file=sys.stderr)
        return

    blob = write_out(args.weeks)
    print(f"wrote {OUT}  ({len(blob['events'])} events, {len(blob['lanes'])} lanes, {len(blob['weeks'])} weeks)")
    os.system(f"open {OUT}")


if __name__ == "__main__":
    main()

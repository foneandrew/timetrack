#!/usr/bin/env python3
"""timetrack — reconstruct a rough, visual picture of where YOUR attention went
each day across parallel git worktrees, for filling in timesheets.

Dumb builder, smart template: this script greps the durable signal sources,
normalises everything to LOCAL time, and emits a JSON blob that gets injected
into template.html. All timeline maths (latest-wins attention, meeting overlay,
toggles) lives in the template's JS.

v1 signals: human-typed Claude prompts + gco/gcod checkouts.
Everything is re-derived each run — no store to maintain.
"""

import argparse
import datetime as dt
import glob
import json
import os
import re
import sys
import urllib.request
from pathlib import Path

HOME = Path.home()
CLAUDE_PROJECTS = HOME / ".claude" / "projects"
GCOD_LOG = HOME / ".timetrack" / "checkouts.log"  # written by the gco/gcod wrapper
REVIEW_LOG = HOME / ".timetrack" / "review.log"   # written by the browser extension host
REVIEW_LANE = "__github_review__"
CONFIG_PATH = Path(__file__).resolve().parent.parent / "config.json"
TEMPLATE = Path(__file__).resolve().parent.parent / "template.html"
OUT = Path(__file__).resolve().parent.parent / "out" / "timetrack.html"

JIRA_RE = re.compile(r"([A-Za-z]+-\d+)")

DEFAULTS = {
    # repo paths whose lane is pinned at the top as the "app" lane
    "app_paths": [str(HOME / "dev" / "cmr-web")],
    "ics_url": None,        # Outlook published calendar .ics (secret — keep out of git)
    "skip_meetings": [],    # meeting title substrings that default to OFF
    "jira_names": {},       # override derived names, e.g. {"PBL-7198": "EFS comparison"}
}


def load_config():
    cfg = dict(DEFAULTS)
    if CONFIG_PATH.exists():
        try:
            cfg.update(json.loads(CONFIG_PATH.read_text()))
        except Exception as e:
            print(f"warning: could not read {CONFIG_PATH}: {e}", file=sys.stderr)
    return cfg


def to_local(ts_str):
    """Parse an ISO timestamp (with Z or offset) and return a LOCAL aware datetime.
    This is the single most important function: every source must pass through it
    so morning UTC timestamps land on the correct local day."""
    if not ts_str:
        return None
    try:
        d = dt.datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
    except ValueError:
        return None
    if d.tzinfo is None:
        d = d.astimezone()  # assume local if naive
    return d.astimezone()


def jira_from(branch):
    if not branch:
        return None
    m = JIRA_RE.search(branch)
    return m.group(1).upper() if m else None


def name_from_branch(branch, jira):
    """Derive a human name for a JIRA from its branch slug.
    'pbl-7198/efs-comparison' + PBL-7198 -> 'efs comparison'."""
    if not branch or not jira:
        return None
    s = re.sub(r"^" + re.escape(jira), "", branch, flags=re.I)  # drop the tag
    s = re.sub(r"[\s/_-]+", " ", s).strip()
    return s or None


def build_jira_names(events, overrides):
    from collections import Counter, defaultdict
    cand = defaultdict(Counter)
    for e in events:
        if e.get("jira") and e.get("branch"):
            n = name_from_branch(e["branch"], e["jira"])
            if n:
                cand[e["jira"]][n] += 1
    names = {j: c.most_common(1)[0][0] for j, c in cand.items()}
    names.update(overrides or {})  # config wins
    return names


def window_bounds(weeks):
    now = dt.datetime.now().astimezone()
    today = now.date()
    monday = today - dt.timedelta(days=today.weekday())
    start_date = monday - dt.timedelta(days=(weeks - 1) * 7)
    start_dt = dt.datetime.combine(start_date, dt.time.min).astimezone()
    return start_dt, now, start_date, today


def lane_meta(cwd, app_paths):
    """Build a stable lane descriptor for a working directory."""
    p = cwd.rstrip("/")
    is_app = any(p == a.rstrip("/") for a in app_paths)
    parts = p.split("/")
    # nice label: for ~/dev/cmr-web-ralph/pbl-7198 -> "cmr-web-ralph/pbl-7198"
    label = "/".join(parts[-2:]) if len(parts) >= 2 else p
    repo = parts[-1]
    return {"id": p, "path": p, "label": label, "repo": repo, "isApp": is_app}


def collect_prompts(start_dt, end_dt, app_paths):
    """Human-typed Claude prompts: type==user, promptSource==typed."""
    events = []
    lanes = {}
    if not CLAUDE_PROJECTS.exists():
        return events, lanes
    start_epoch = start_dt.timestamp()
    for fp in glob.glob(str(CLAUDE_PROJECTS / "*" / "*.jsonl")):
        # cheap skip: file untouched before the window can't hold in-window events
        try:
            if os.path.getmtime(fp) < start_epoch:
                continue
        except OSError:
            continue
        with open(fp, "r", errors="replace") as fh:
            for line in fh:
                if '"typed"' not in line:
                    continue
                try:
                    d = json.loads(line)
                except Exception:
                    continue
                if d.get("type") != "user" or d.get("promptSource") != "typed":
                    continue
                local = to_local(d.get("timestamp"))
                if not local or not (start_dt <= local <= end_dt):
                    continue
                cwd = d.get("cwd")
                if not cwd:
                    continue
                msg = d.get("message") or {}
                c = msg.get("content") if isinstance(msg, dict) else None
                preview = " ".join(c.split())[:90] if isinstance(c, str) else None
                lm = lane_meta(cwd, app_paths)
                lanes[lm["id"]] = lm
                events.append({
                    "date": local.date().isoformat(),
                    "minute": local.hour * 60 + local.minute,
                    "ts": local.isoformat(),
                    "lane": lm["id"],
                    "jira": jira_from(d.get("gitBranch")),
                    "branch": d.get("gitBranch"),
                    "type": "prompt",
                    "preview": preview,
                })
    return events, lanes


def collect_checkouts(start_dt, end_dt, app_paths):
    """gco/gcod wrapper log lines: <epoch>\t<cwd>\t<branch>\t<action>."""
    events = []
    lanes = {}
    if not GCOD_LOG.exists():
        return events, lanes
    for line in GCOD_LOG.read_text(errors="replace").splitlines():
        parts = line.split("\t")
        if len(parts) < 4:
            continue
        epoch, cwd, branch, action = parts[0], parts[1], parts[2], parts[3]
        try:
            local = dt.datetime.fromtimestamp(int(epoch)).astimezone()
        except (ValueError, OverflowError):
            continue
        if not (start_dt <= local <= end_dt) or not cwd:
            continue
        lm = lane_meta(cwd, app_paths)
        lanes[lm["id"]] = lm
        events.append({
            "date": local.date().isoformat(),
            "minute": local.hour * 60 + local.minute,
            "ts": local.isoformat(),
            "lane": lm["id"],
            "jira": jira_from(branch),
            "branch": branch or None,
            "type": action if action in ("gco", "gcod") else "checkout",
        })
    return events, lanes


# ------------------------- calendar (ICS) -------------------------
WD = {"MO": 0, "TU": 1, "WE": 2, "TH": 3, "FR": 4, "SA": 5, "SU": 6}


def fetch_ics(url, timeout=20):
    req = urllib.request.Request(url, headers={"User-Agent": "timetrack"})
    with urllib.request.urlopen(req, timeout=timeout) as r:
        return r.read().decode("utf-8", "replace")


def unfold(text):
    """RFC5545 line unfolding: a leading space/tab continues the previous line."""
    out = []
    for line in text.splitlines():
        if line[:1] in (" ", "\t") and out:
            out[-1] += line[1:]
        else:
            out.append(line)
    return out


def parse_vevents(lines):
    """Collect VEVENT property dicts, skipping VTIMEZONE (its DST rules are not meetings)."""
    events, cur, in_tz = [], None, False
    for ln in lines:
        if ln == "BEGIN:VTIMEZONE":
            in_tz = True; continue
        if ln == "END:VTIMEZONE":
            in_tz = False; continue
        if in_tz:
            continue
        if ln == "BEGIN:VEVENT":
            cur = {}; continue
        if ln == "END:VEVENT":
            if cur is not None:
                events.append(cur); cur = None
            continue
        if cur is None or ":" not in ln:
            continue
        name_params, _, val = ln.partition(":")
        bits = name_params.split(";")
        name = bits[0].upper()
        params = {}
        for p in bits[1:]:
            if "=" in p:
                k, v = p.split("=", 1)
                params[k.upper()] = v
        if name in ("DTSTART", "DTEND"):
            cur[name] = (val, params)
        elif name == "EXDATE":
            cur.setdefault("EXDATE", []).append((val, params))
        else:
            cur[name] = val
    return events


def ics_unescape(s):
    out = s.replace("\\\\", "\x00").replace("\\n", " ").replace("\\N", " ").replace("\\,", ",").replace("\\;", ";")
    return " ".join(out.replace("\x00", "\\").split())


def parse_ics_dt(value, params=None):
    """Return (local-aware datetime, is_all_day). TZID times are treated as local
    wall-clock (machine is NZ); Z values are converted from UTC."""
    params = params or {}
    v = value.strip()
    if params.get("VALUE") == "DATE" or (len(v) == 8 and "T" not in v):
        return dt.datetime.strptime(v, "%Y%m%d").astimezone(), True
    if v.endswith("Z"):
        return dt.datetime.strptime(v, "%Y%m%dT%H%M%SZ").replace(tzinfo=dt.timezone.utc).astimezone(), False
    return dt.datetime.strptime(v[:15], "%Y%m%dT%H%M%S").astimezone(), False


def nth_weekday(year, month, wd, nth):
    """nth (1-based, or -1 for last) weekday `wd` in a given month."""
    if nth > 0:
        d = dt.date(year, month, 1)
        d += dt.timedelta(days=(wd - d.weekday()) % 7)
        d += dt.timedelta(weeks=nth - 1)
        return d if d.month == month else None
    # last
    if month == 12:
        d = dt.date(year, 12, 31)
    else:
        d = dt.date(year, month + 1, 1) - dt.timedelta(days=1)
    d -= dt.timedelta(days=(d.weekday() - wd) % 7)
    return d


def expand_rrule(start_dt, rrule, win_end):
    """Expand a recurrence to local-aware occurrence datetimes up to win_end (date)."""
    parts = dict(p.split("=", 1) for p in rrule.split(";") if "=" in p)
    freq = parts.get("FREQ")
    interval = int(parts.get("INTERVAL", "1") or 1)
    count = int(parts["COUNT"]) if "COUNT" in parts else None
    until = None
    if "UNTIL" in parts:
        try:
            until = parse_ics_dt(parts["UNTIL"])[0].date()
        except Exception:
            until = None
    byday = parts.get("BYDAY")
    t = start_dt.timetz()
    stop = min(until, win_end) if until else win_end
    occ, n, guard = [], 0, 0

    def keep(cand):
        nonlocal n
        occ.append(cand)
        n += 1
        return not (count and n >= count)

    if freq == "WEEKLY":
        days = sorted(WD[d[-2:]] for d in byday.split(",")) if byday else [start_dt.weekday()]
        week = start_dt.date() - dt.timedelta(days=start_dt.weekday())
        while week <= stop and guard < 1500:
            guard += 1
            for wd in days:
                d = week + dt.timedelta(days=wd)
                if d < start_dt.date() or d > stop:
                    continue
                if not keep(dt.datetime.combine(d, t)):
                    return occ
            week += dt.timedelta(weeks=interval)
    elif freq == "DAILY":
        d = start_dt
        while d.date() <= stop and guard < 3000:
            guard += 1
            if not keep(d):
                return occ
            d += dt.timedelta(days=interval)
    elif freq == "MONTHLY":
        bymd = parts.get("BYMONTHDAY")
        y, mo = start_dt.year, start_dt.month
        while guard < 400:
            guard += 1
            cand_date = None
            if bymd:
                try:
                    cand_date = dt.date(y, mo, int(bymd.split(",")[0]))
                except ValueError:
                    cand_date = None
            elif byday:
                m = re.match(r"(-?\d+)([A-Z]{2})", byday.split(",")[0])
                if m:
                    cand_date = nth_weekday(y, mo, WD[m.group(2)], int(m.group(1)))
            else:
                try:
                    cand_date = dt.date(y, mo, start_dt.day)
                except ValueError:
                    cand_date = None
            if cand_date and cand_date >= start_dt.date():
                if cand_date > stop:
                    break
                if not keep(dt.datetime.combine(cand_date, t)):
                    return occ
            mo += interval
            while mo > 12:
                mo -= 12; y += 1
    else:
        occ = [start_dt]  # unknown/unsupported freq → just the base occurrence
    return occ


def expand_meeting(ev, win_start, win_end):
    if "DTSTART" not in ev:
        return []
    start_dt, all_day = parse_ics_dt(*ev["DTSTART"])
    if all_day:
        return []  # all-day events don't paint the working-hours timeline
    if "DTEND" in ev:
        dur = parse_ics_dt(*ev["DTEND"])[0] - start_dt
    else:
        dur = dt.timedelta(minutes=30)
    title = ics_unescape(ev.get("SUMMARY") or "(no title)")
    status = ev.get("STATUS", "")
    busy = ev.get("X-MICROSOFT-CDO-BUSYSTATUS", "")
    exset = set()
    for val, params in ev.get("EXDATE", []):
        for piece in val.split(","):
            try:
                exset.add(parse_ics_dt(piece, params)[0].date())
            except Exception:
                pass
    starts = expand_rrule(start_dt, ev["RRULE"], win_end) if ev.get("RRULE") else [start_dt]
    out = []
    for s in starts:
        if s.date() in exset or not (win_start <= s.date() <= win_end) or s.weekday() >= 5:
            continue
        e = s + dur
        out.append({
            "date": s.date().isoformat(),
            "startMin": s.hour * 60 + s.minute,
            "endMin": (e.hour * 60 + e.minute) if e.date() == s.date() else 24 * 60,
            "title": title, "busy": busy, "status": status,
        })
    return out


def collect_meetings(cfg, start_date, today):
    url = cfg.get("ics_url")
    if not url:
        return []
    try:
        events = parse_vevents(unfold(fetch_ics(url)))
    except Exception as e:
        print(f"warning: calendar fetch/parse failed: {e}", file=sys.stderr)
        return []
    skip = [s.lower() for s in cfg.get("skip_meetings", [])]
    meetings, seen = [], set()
    for ev in events:
        for m in expand_meeting(ev, start_date, today):
            m["id"] = f'{m["date"]}|{m["startMin"]}|{m["title"]}'
            if m["id"] in seen:
                continue
            seen.add(m["id"])
            tl = m["title"].lower()
            m["defaultOn"] = (m["busy"] != "FREE" and m["status"] != "CANCELLED"
                              and not tl.startswith("canceled:") and not tl.startswith("cancelled:")
                              and not any(s in tl for s in skip))
            meetings.append(m)
    meetings.sort(key=lambda m: (m["date"], m["startMin"]))
    return meetings


# A review only counts once you've dwelled: a session is consecutive ticks on
# the same JIRA (gaps <= SESSION_GAP); sessions with fewer than MIN_TICKS ticks
# are fly-by glances and get dropped. Raw ticks stay in the log so the
# threshold can be retuned later.
SESSION_GAP = 300   # seconds; ticks are ~75s apart
MIN_TICKS = 2


def collect_reviews(start_dt, end_dt):
    """GitHub PR review heartbeat ticks: <epoch>\t<jira>\t<url>\t<title>."""
    if not REVIEW_LOG.exists():
        return [], {}
    raw = []
    for line in REVIEW_LOG.read_text(errors="replace").splitlines():
        parts = line.split("\t")
        if not parts or not parts[0]:
            continue
        try:
            epoch = int(parts[0])
        except ValueError:
            continue
        jira = parts[1] if len(parts) > 1 else ""
        url = parts[2] if len(parts) > 2 else ""
        title = parts[3] if len(parts) > 3 else ""
        local = dt.datetime.fromtimestamp(epoch).astimezone()
        if not (start_dt <= local <= end_dt):
            continue
        raw.append({"epoch": epoch, "local": local,
                    "jira": jira or jira_from(title) or jira_from(url),
                    "title": title, "url": url})
    raw.sort(key=lambda t: t["epoch"])

    # group into dwell sessions, keep only those with >= MIN_TICKS ticks
    events = []
    i = 0
    while i < len(raw):
        j = i + 1
        while (j < len(raw) and raw[j]["epoch"] - raw[j - 1]["epoch"] <= SESSION_GAP
               and raw[j]["jira"] == raw[i]["jira"]):
            j += 1
        if j - i >= MIN_TICKS:
            for t in raw[i:j]:
                lc = t["local"]
                events.append({
                    "date": lc.date().isoformat(),
                    "minute": lc.hour * 60 + lc.minute,
                    "ts": lc.isoformat(),
                    "lane": REVIEW_LANE,
                    "jira": t["jira"] or None,
                    "branch": None,
                    "type": "review",
                    "preview": t["title"] or t["url"],
                })
        i = j

    lane = {REVIEW_LANE: {"id": REVIEW_LANE, "path": REVIEW_LANE, "label": "GitHub review",
                          "repo": "review", "isApp": False, "isReview": True}} if events else {}
    return events, lane


def build_weeks(start_date, today):
    """Mon–Fri columns per ISO week across the window."""
    weeks = []
    monday = start_date - dt.timedelta(days=start_date.weekday())
    cur_monday = today - dt.timedelta(days=today.weekday())
    while monday <= cur_monday:
        days = []
        for i in range(5):  # Mon..Fri
            d = monday + dt.timedelta(days=i)
            days.append({
                "date": d.isoformat(),
                "weekday": d.strftime("%A"),
                "short": d.strftime("%a %-d %b"),
                "isToday": d == today,
            })
        iso_year, iso_week, _ = monday.isocalendar()
        weeks.append({
            "iso": f"{iso_year}-W{iso_week:02d}",
            "label": f"{monday.strftime('%-d %b')} – {(monday + dt.timedelta(days=4)).strftime('%-d %b')}",
            "monday": monday.isoformat(),
            "isCurrent": monday == cur_monday,
            "days": days,
        })
        monday += dt.timedelta(days=7)
    return weeks


def main():
    ap = argparse.ArgumentParser(description="Build the timetrack visual.")
    ap.add_argument("-w", "--weeks", type=int, default=4,
                    help="number of weeks to scan, ending this week (default 4)")
    ap.add_argument("--json", action="store_true", help="print JSON to stdout, don't write HTML")
    args = ap.parse_args()

    cfg = load_config()
    app_paths = cfg["app_paths"]
    start_dt, end_dt, start_date, today = window_bounds(args.weeks)

    p_events, p_lanes = collect_prompts(start_dt, end_dt, app_paths)
    c_events, c_lanes = collect_checkouts(start_dt, end_dt, app_paths)
    r_events, r_lanes = collect_reviews(start_dt, end_dt)

    lanes = {**p_lanes, **c_lanes, **r_lanes}
    events = sorted(p_events + c_events + r_events, key=lambda e: e["ts"])

    blob = {
        "generatedAt": end_dt.isoformat(),
        "tz": str(end_dt.tzinfo),
        "window": {
            "start": start_dt.date().isoformat(),
            "end": today.isoformat(),
            "weeks": args.weeks,
        },
        "frame": {"startMin": 8 * 60, "endMin": 17 * 60, "idleTailMin": 30},
        "lanes": lanes,
        "events": events,
        "jiraNames": build_jira_names(events, cfg.get("jira_names")),
        "meetings": collect_meetings(cfg, start_date, today),
        "weeks": build_weeks(start_date, today),
        "config": {"appPaths": app_paths, "skipMeetings": cfg["skip_meetings"]},
    }

    if args.json:
        print(json.dumps(blob, indent=2))
        return

    if not TEMPLATE.exists():
        print(json.dumps(blob, indent=2))
        print(f"\n(no template at {TEMPLATE} yet — printed JSON instead)", file=sys.stderr)
        return

    html = TEMPLATE.read_text()
    payload = "window.__TIMETRACK__ = " + json.dumps(blob) + ";"
    html = html.replace("/*__TIMETRACK_DATA__*/", payload)
    OUT.parent.mkdir(parents=True, exist_ok=True)
    OUT.write_text(html)
    print(f"wrote {OUT}  ({len(events)} events, {len(lanes)} lanes, {len(blob['weeks'])} weeks)")
    os.system(f"open {OUT}")


if __name__ == "__main__":
    main()
